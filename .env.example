# Unified LLM Configuration (OpenAI SDK)
# Works with OpenAI, Ollama, Azure OpenAI, and other OpenAI-compatible providers
OPENAI_API_KEY=not-needed  # Use "not-needed" for Ollama, real key for OpenAI/Azure
OPENAI_MODEL=gemma3:270m   # Model name (e.g., gpt-4-mini, llama2, gemma3:270m)
OPENAI_BASE_URL=http://localhost:11434  # Optional: Leave empty for OpenAI, set for Ollama/Azure

# Configuration Examples:
# -------------------
# 1. For Ollama (local):
#    OPENAI_API_KEY=not-needed
#    OPENAI_MODEL=gemma3:270m
#    OPENAI_BASE_URL=http://localhost:11434
#
# 2. For OpenAI (cloud):
#    OPENAI_API_KEY=sk-your-key-here
#    OPENAI_MODEL=gpt-4-mini
#    OPENAI_BASE_URL=  # Leave empty
#
# 3. For Azure OpenAI:
#    OPENAI_API_KEY=your-azure-key
#    OPENAI_MODEL=your-deployment-name
#    OPENAI_BASE_URL=https://<name>.openai.azure.com/openai/deployments/<deployment>

AGENT_SYSTEM_PROMPT=You are a helpful software engineering assistant.

DATABASE_URL=postgresql+psycopg://agent_user:agent_password@localhost:5432/agent_assistant
REDIS_URL=redis://localhost:6379/0
REDIS_CHAT_CACHE_TTL_SECONDS=3600
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT_SECONDS=30

JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO

POSTGRES_DB=agent_assistant
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=agent_password
POSTGRES_PORT=5432
REDIS_PORT=6379

# Document pipeline infra
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_NAME=documents
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

RABBITMQ_URL=amqp://guest:guest@localhost:5672/%2F
RABBITMQ_DOCUMENT_EXCHANGE=documents.exchange
RABBITMQ_DOCUMENT_ROUTING_KEY=documents.uploaded
RABBITMQ_DOCUMENT_QUEUE=documents.uploaded.queue
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

DOCUMENT_CHUNK_SIZE_BYTES=1048576

# RAG pipeline — queue names (all have matching DLQs)
RABBITMQ_DOCUMENT_FANOUT_EXCHANGE=documents.fanout
RABBITMQ_PARSE_QUEUE=documents.parse.queue
RABBITMQ_PARSE_DLQ=documents.parse.dlq
RABBITMQ_CHUNK_QUEUE=documents.chunk.queue
RABBITMQ_CHUNK_DLQ=documents.chunk.dlq
RABBITMQ_EMBED_QUEUE=documents.embed.queue
RABBITMQ_EMBED_DLQ=documents.embed.dlq
RABBITMQ_STORE_QUEUE=documents.store.queue
RABBITMQ_STORE_DLQ=documents.store.dlq

# Chunker settings (token-based, using tiktoken cl100k_base by default)
CHUNK_WINDOW_TOKENS=512
CHUNK_OVERLAP_TOKENS=50
CHUNK_ENCODING=cl100k_base

# Embedding model — independent of the chat LLM
# Falls back to OPENAI_API_KEY / OPENAI_BASE_URL when not set.
# Set these if your embedding provider differs from your chat provider.
#   OpenAI:  EMBEDDING_API_KEY=sk-...   (leave EMBEDDING_BASE_URL empty)
#   Ollama:  EMBEDDING_API_KEY=not-needed  EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=not-needed
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=bge-large
EMBEDDING_DIMENSION=1536
EMBEDDING_MAX_RETRIES=3

# Vector backend — "qdrant" (default, self-hosted via compose) or "pinecone" (cloud SaaS)
VECTOR_BACKEND=qdrant

# Qdrant (used when VECTOR_BACKEND=qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=agent-documents

# Pinecone (used when VECTOR_BACKEND=pinecone — cloud-hosted, no container needed)
# Sign up at https://pinecone.io to get an API key and create a project
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=agent-documents
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
