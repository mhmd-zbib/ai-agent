# ============================================================
# Pipeline worker — environment variables
# Copy to .env and fill in the required values.
# ============================================================

# === RabbitMQ ===
# Required: AMQP connection string
AMQP_URL=amqp://guest:guest@localhost:5672/%2F
# PIPELINE_QUEUE=pipeline.ingest
# PIPELINE_DLQ=pipeline.ingest.dlq

# === LLM / Embeddings ===
# Stage 4 (embedding) uses OpenAI SDK
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-large

# Stage 3 (metadata generation) uses Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# === PostgreSQL (asyncpg) ===
# Use standard postgresql:// format — asyncpg connects directly (no SQLAlchemy)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_db

# === Logging ===
# LOG_LEVEL=INFO
