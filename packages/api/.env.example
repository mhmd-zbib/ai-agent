# ============================================================
# API — environment variables
# Copy to .env and fill in the required values.
# ============================================================

# === LLM (OpenAI or compatible) ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Uncomment to point at Ollama or another OpenAI-compatible endpoint
# OPENAI_BASE_URL=http://localhost:11434/v1

# === Embeddings ===
# Falls back to OPENAI_API_KEY / standard OpenAI endpoint when not set
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MAX_RETRIES=3

# === PostgreSQL ===
# Use postgresql+psycopg:// (psycopg3 sync driver required by SQLAlchemy)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agent_db
# POSTGRES_POOL_SIZE=5
# POSTGRES_MAX_OVERFLOW=10
# POSTGRES_POOL_TIMEOUT_SECONDS=30

# === Redis ===
REDIS_URL=redis://localhost:6379/0
# REDIS_CHAT_CACHE_TTL_SECONDS=3600

# === Auth (JWT) ===
JWT_SECRET_KEY=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# === MinIO (object storage) ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=documents
# MINIO_SECURE=false

# === RabbitMQ ===
RABBITMQ_URL=amqp://guest:guest@localhost:5672/%2F
# RABBITMQ_DOCUMENT_EXCHANGE=documents.exchange
# RABBITMQ_DOCUMENT_ROUTING_KEY=documents.uploaded

# === Vector backend ===
# qdrant (self-hosted) or pinecone (cloud SaaS)
VECTOR_BACKEND=qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_COLLECTION=agent-documents

# Pinecone — only required when VECTOR_BACKEND=pinecone
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=agent-documents
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1

# === Logging ===
# LOG_LEVEL=INFO

# === Feature flags ===
# ENABLE_DEMO_TOOLS=false
