# Test your FastAPI endpoints

# Health check
GET http://127.0.0.1:8000/health
Accept: application/json

###

# Login first to get a bearer token
POST http://127.0.0.1:8000/v1/users/login
Content-Type: application/json
Accept: application/json

{
  "email": "test@example.com",
  "password": "password123"
}

###

# Create a chat session
POST http://127.0.0.1:8000/v1/agent/sessions
Accept: application/json
Authorization: Bearer replace-with-access-token

###

# Start a chat turn using the created session_id
POST http://127.0.0.1:8000/v1/agent/chat
Content-Type: application/json
Accept: application/json
Authorization: Bearer replace-with-access-token

{
  "session_id": "replace-with-session-id",
  "message": "Hey agent, give me a 3-step plan to learn FastAPI."
}

###

# Continue the same chat with only the new message
POST http://127.0.0.1:8000/v1/agent/chat
Content-Type: application/json
Accept: application/json
Authorization: Bearer replace-with-access-token

{
  "session_id": "replace-with-session-id",
  "message": "Now make it a weekly schedule."
}

###

# Reset a session when done
DELETE http://127.0.0.1:8000/v1/agent/sessions/replace-with-session-id
Accept: application/json
Authorization: Bearer replace-with-access-token
